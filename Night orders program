<script>
let allOrders = {};
let curFilter = 'all';
let selSrcVal = '';

function switchTab(name, btn) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
}

function selSrc(s) {
  selSrcVal = s;
  document.querySelectorAll('.src-btn').forEach(b => b.classList.remove('sel'));
  document.getElementById('src-' + s).classList.add('sel');
}

function addProd() {
  const list = document.getElementById('prodList');
  const row = document.createElement('div');
  row.className = 'prod-row';
  row.innerHTML = `
    <input type="text" placeholder="اسم المنتج">
    <input type="number" min="1" value="1">
    <select><option>متر</option><option>قطعة</option><option>كيس</option><option>دزينة</option><option>لفة</option></select>
    <button class="del-btn" onclick="this.parentElement.remove()">×</button>`;
  list.appendChild(row);
}

function getProds() {
  return [...document.querySelectorAll('#prodList .prod-row')].map(r => {
    const inputs = r.querySelectorAll('input');
    return { name: inputs[0].value.trim(), qty: inputs[1].value || '1', unit: r.querySelector('select').value };
  }).filter(p => p.name);
}

async function submitOrder() {
  if (!window._firebaseReady) { showToast('⚠️ جاري الاتصال، انتظر لحظة'); return; }
  const name = document.getElementById('cName').value.trim();
  const city = document.getElementById('cCity').value;
  if (!name) { showToast('⚠️ يرجى إدخال اسم الزبون'); return; }
  if (!city) { showToast('⚠️ يرجى اختيار المحافظة'); return; }
  if (!selSrcVal) { showToast('⚠️ يرجى اختيار مصدر الطلب'); return; }
  const prods = getProds();
  if (!prods.length) { showToast('⚠️ يرجى إضافة منتج واحد على الأقل'); return; }

  const btn = document.getElementById('submitBtn');
  btn.disabled = true; btn.textContent = '⏳ جاري الحفظ...';

  try {
    await window._push(window._ordersRef, {
      name, city,
      phone: document.getElementById('cPhone').value.trim(),
      notes: document.getElementById('cNotes').value.trim(),
      products: prods, source: selSrcVal, status: 'pending',
      time: new Date().toLocaleString('ar-IQ')
    });
    showToast('✅ تم حفظ الطلب ومشاركته فوراً!');
    resetForm();
  } catch(e) {
    showToast('❌ خطأ: ' + e.message);
  }
  btn.disabled = false;
  btn.textContent = '✅ حفظ الطلب ومشاركته فوراً';
}

function resetForm() {
  ['cName','cPhone','cNotes'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('cCity').value = '';
  document.getElementById('prodList').innerHTML = `<div class="prod-row">
    <input type="text" placeholder="اسم المنتج">
    <input type="number" min="1" value="1">
    <select><option>متر</option><option>قطعة</option><option>كيس</option><option>دزينة</option><option>لفة</option></select>
  </div>`;
  selSrcVal = '';
  document.querySelectorAll('.src-btn').forEach(b => b.classList.remove('sel'));
}

// Firebase connection events
window.addEventListener('firebaseReady', () => {
  window._onValue(window._ordersRef, snap => {
    allOrders = snap.val() || {};
    renderOrders();
  });
});

window.addEventListener('firebaseConnected', () => {
  const badge = document.getElementById('liveBadge');
  badge.classList.remove('disconnected');
  document.getElementById('liveText').textContent = 'متصل مباشر';
  const banner = document.getElementById('connBanner');
  if (banner) { banner.className = 'conn-banner conn-ok'; banner.textContent = '🟢 متصل — المزامنة تعمل بشكل مثالي'; }
});

window.addEventListener('firebaseDisconnected', () => {
  const badge = document.getElementById('liveBadge');
  badge.classList.add('disconnected');
  document.getElementById('liveText').textContent = 'غير متصل';
  const banner = document.getElementById('connBanner');
  if (banner) { banner.className = 'conn-banner conn-err'; banner.textContent = '🔴 انقطع الاتصال — تحقق من الإنترنت'; }
});

window.addEventListener('firebaseError', (e) => {
  const banner = document.getElementById('connBanner');
  if (banner) { banner.className = 'conn-banner conn-err'; banner.textContent = '🔴 خطأ: ' + e.detail; }
});

function renderOrders() {
  const list = document.getElementById('ordersList');
  const entries = Object.entries(allOrders).reverse();
  const filtered = curFilter === 'all' ? entries : entries.filter(([,o]) => o.status === curFilter);

  document.getElementById('s-total').textContent = entries.length;
  document.getElementById('s-pending').textContent = entries.filter(([,o]) => o.status === 'pending').length;
  document.getElementById('s-done').textContent = entries.filter(([,o]) => o.status === 'done').length;

  if (!filtered.length) {
    list.innerHTML = `<div class="empty"><div class="ei">📭</div><h3>لا يوجد طلبات</h3><p>الطلبات ستظهر هنا فور تسجيلها</p></div>`;
    return;
  }

  const sMap = { pending:'جديد ⏳', confirmed:'مؤكد ✅', shipped:'شُحن 🚚', done:'منجز 🎉' };
  const sCls = { pending:'b-pending', confirmed:'b-confirmed', shipped:'b-shipped', done:'b-done' };

  list.innerHTML = filtered.map(([id, o]) => `
    <div class="order-card">
      <div class="oc-top">
        <div><div class="oc-name">${o.name}</div><div class="oc-time">🕐 ${o.time}</div></div>
        <div class="oc-city">📍 ${o.city}</div>
      </div>
      <span class="badge ${o.source==='ig'?'b-ig':'b-wa'}">${o.source==='ig'?'📸 إنستغرام':'💬 واتساب'}</span>
      <span class="badge ${sCls[o.status]}">${sMap[o.status]}</span>
      ${o.phone?`<div class="oc-phone">📞 ${o.phone}</div>`:''}
      <div class="oc-products">${(o.products||[]).map(p=>`<span class="ptag">🧵 ${p.name} — ${p.qty} ${p.unit}</span>`).join('')}</div>
      ${o.notes?`<div class="oc-notes">📝 ${o.notes}</div>`:''}
      <div class="oc-actions">
        ${o.status==='pending'?`<button class="abtn a-confirm" onclick="updStatus('${id}','confirmed')">✅ تأكيد</button>`:''}
        ${o.status==='confirmed'?`<button class="abtn a-ship" onclick="updStatus('${id}','shipped')">🚚 تم الشحن</button>`:''}
        ${o.status==='shipped'?`<button class="abtn a-done" onclick="updStatus('${id}','done')">🎉 منجز</button>`:''}
        <button class="abtn a-del" onclick="delOrder('${id}')">🗑️ حذف</button>
      </div>
    </div>`).join('');
}

async function updStatus(id, status) {
  try {
    await window._update(window._ref(window._db, 'orders/' + id), { status });
    showToast('✅ تم تحديث الحالة');
  } catch(e) { showToast('❌ خطأ في التحديث'); }
}

async function delOrder(id) {
  if (confirm('حذف هذا الطلب نهائياً؟')) {
    try {
      await window._remove(window._ref(window._db, 'orders/' + id));
      showToast('🗑️ تم حذف الطلب');
    } catch(e) { showToast('❌ خطأ في الحذف'); }
  }
}

function setFilter(f, btn) {
  curFilter = f;
  document.querySelectorAll('.fbtn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderOrders();
}

function toggleCk(el) {
  el.classList.toggle('done');
  el.querySelector('.ck-box').textContent = el.classList.contains('done') ? '✓' : '';
}

function resetCk() {
  document.querySelectorAll('.ck-item').forEach(el => {
    el.classList.remove('done');
    el.querySelector('.ck-box').textContent = '';
  });
  showToast('🔄 تم إعادة تعيين القائمة');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}
</script>

</body>
</html>
