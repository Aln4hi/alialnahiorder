<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import { getDatabase, ref, push, onValue, update, remove }
    from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

  // ✅ YOUR FIREBASE CONFIG
  const firebaseConfig = {
    apiKey: "AIzaSyCUPoopTi04WCmqscRyRLT-JXXdTz-zFp8",
    authDomain: "order-fills.firebaseapp.com",
    databaseURL: "https://order-fills-default-rtdb.europe-west1.firebasedatabase.app",
    projectId: "order-fills",
    storageBucket: "order-fills.firebasestorage.app",
    messagingSenderId: "409088625500",
    appId: "1:409088625500:web:68402b3bba8a0c67548f99"
  };

  try {
    const app = initializeApp(firebaseConfig);
    const db = getDatabase(app);
    const ordersRef = ref(db, 'orders');

    window._db = db;
    window._ref = ref;
    window._push = push;
    window._onValue = onValue;
    window._update = update;
    window._remove = remove;
    window._ordersRef = ordersRef;
    window._firebaseReady = true;

    // Test connection immediately
    onValue(ref(db, '.info/connected'), (snap) => {
      if (snap.val() === true) {
        window._connected = true;
        window.dispatchEvent(new Event('firebaseConnected'));
      } else {
        window._connected = false;
        window.dispatchEvent(new Event('firebaseDisconnected'));
      }
    });

    window.dispatchEvent(new Event('firebaseReady'));
  } catch(e) {
    window.dispatchEvent(new CustomEvent('firebaseError', { detail: e.message }));
  }
</script>

<style>
